<Window x:Class="Snapture.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="#01000000"
        Topmost="True"
        Focusable="True"
        Cursor="Cross"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Canvas x:Name="RootCanvas" ClipToBounds="True">
        <!-- The dim is rendered by a separate GPU-composited DimWindow behind this
             one; this window stays a lightweight input + chrome layer. -->

        <!-- Selection outline -->
        <Rectangle x:Name="SelectionBorder"
                   Stroke="#F04747" StrokeThickness="1.5"
                   Visibility="Collapsed" />

        <!-- Size badge -->
        <Border x:Name="InfoBadge" Background="#CC000000" CornerRadius="4"
                Padding="8,4" Visibility="Collapsed">
            <TextBlock x:Name="InfoText" Foreground="White" FontSize="12"
                       FontFamily="Consolas" />
        </Border>

        <!-- First-run hint -->
        <Border x:Name="HintBadge" Background="#CC000000" CornerRadius="6" Padding="14,10">
            <TextBlock x:Name="HintText" Foreground="White" FontSize="13"
                       TextAlignment="Center"
                       Text="Hover to snap to a UI area  •  Scroll for its parent  •  Click to lock it in  •  Drag for a custom area  •  Enter to record  •  Esc to cancel" />
        </Border>

        <!-- Operable toolbar (rendered last → always above the dim).
             Opaque background and SizeAll cursor so it reads as draggable; drag
             it by any empty area to move it out of the way. -->
        <Border x:Name="Toolbar" CornerRadius="10" Padding="10,8"
                Background="#FF2B2B2B" Cursor="SizeAll"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="Black" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Drag handle (the whole bar is draggable; this is the affordance). -->
                <TextBlock Text="&#xE76F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Cursor="SizeAll"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" ToolTip="Drag to move" />

                <!-- Lead with the capture kind: still snapshot vs video (icons only). -->
                <Border Style="{StaticResource SegmentedContainer}" VerticalAlignment="Center">
                    <UniformGrid Rows="1" Columns="2">
                        <RadioButton x:Name="KindSnapshot" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="OverlayKind" MinWidth="46" ToolTip="Snapshot (still image)"
                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="17" Content="&#xE722;" />
                        <RadioButton x:Name="KindVideo" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="OverlayKind" MinWidth="46" ToolTip="Video recording"
                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="17" Content="&#xE714;" />
                    </UniformGrid>
                </Border>

                <Border Style="{StaticResource SegmentedContainer}" VerticalAlignment="Center" Margin="12,0,0,0">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="ModeDisplay" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="OverlayMode" Content="Display" MinWidth="78" />
                        <RadioButton x:Name="ModeWindow" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="OverlayMode" Content="Window" MinWidth="78" />
                        <RadioButton x:Name="ModeCustom" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="OverlayMode" Content="Custom" MinWidth="78" />
                    </UniformGrid>
                </Border>

                <Button x:Name="RecordButton" Style="{StaticResource RecordButton}"
                        Content="● Record" Margin="12,0,0,0" />
                <Button x:Name="CancelButton" Content="&#xE711;" ToolTip="Cancel (Esc)"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                        Margin="8,0,0,0" Padding="11,8" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
