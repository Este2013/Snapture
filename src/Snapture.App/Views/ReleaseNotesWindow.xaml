<Window x:Class="Snapture.App.Views.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Release notes"
        Width="484" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" Background="Transparent"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Border Margin="12" CornerRadius="10" Background="#FF1F1F1F"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.5" Color="Black" />
        </Border.Effect>
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderBar" Grid.Row="0" Background="Transparent" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" />
                <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,2,0,0" Visibility="Collapsed"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button x:Name="HeaderClose" Grid.Column="1" Style="{StaticResource IconButton}"
                    Content="&#xE8BB;" ToolTip="Close" VerticalAlignment="Top" />
        </Grid>

        <Border Grid.Row="1" CornerRadius="6" Padding="14,12"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="NotesText" TextWrapping="Wrap" LineHeight="20"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressBar x:Name="DownloadProgress" Width="150" Height="6" Minimum="0" Maximum="100"
                             Visibility="Collapsed" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="InstallButton" Style="{StaticResource AccentButton}"
                        Content="Install update" Padding="16,8" />
            </StackPanel>
        </Grid>
        </Grid>
    </Border>
</Window>
