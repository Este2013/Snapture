<Window x:Class="Snapture.App.Views.RecordingBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Border CornerRadius="10" Padding="14,9"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="Black" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Ellipse Width="12" Height="12" Fill="{StaticResource RecordAccentBrush}"
                     VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.25" Duration="0:0:0.7" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock x:Name="ElapsedText" Text="00:00" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="16" MinWidth="52" />
            <Button x:Name="StopButton" Style="{StaticResource RecordButton}"
                    Content="■ Stop" Margin="14,0,0,0" />
        </StackPanel>
    </Border>
</Window>
