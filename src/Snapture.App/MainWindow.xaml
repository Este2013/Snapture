<Window x:Class="Snapture.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapture"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Window.Resources>
        <!-- Shared column layout for a settings row: label left, value right. -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Ellipse Width="22" Height="22" Stroke="{StaticResource RecordAccentBrush}"
                     StrokeThickness="3" VerticalAlignment="Center" />
            <TextBlock Text="Snapture" FontSize="22" FontWeight="SemiBold"
                       Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Mode tabs -->
        <Border Grid.Row="1" Style="{StaticResource SegmentedContainer}"
                HorizontalAlignment="Stretch" Margin="0,0,0,16">
            <UniformGrid Rows="1" Columns="2">
                <RadioButton x:Name="TabSnapshot" Style="{StaticResource SegmentRadioButton}"
                             GroupName="SettingsTab" Content="📷 Snapshot" />
                <RadioButton x:Name="TabVideo" Style="{StaticResource SegmentRadioButton}"
                             GroupName="SettingsTab" Content="🎬 Snapture" />
            </UniformGrid>
        </Border>

        <!-- Mode-specific settings -->
        <Grid Grid.Row="2">
            <!-- ===== Snapshot settings ===== -->
            <Grid x:Name="SnapshotPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Output format" Style="{StaticResource SettingLabel}" />
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SegmentedContainer}"
                        Margin="0,8" HorizontalAlignment="Right">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="SnapFormatPng" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapFormat" Content="PNG" MinWidth="76" />
                        <RadioButton x:Name="SnapFormatJpeg" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapFormat" Content="JPEG" MinWidth="76" />
                        <RadioButton x:Name="SnapFormatWebp" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapFormat" Content="WebP" MinWidth="76" />
                    </UniformGrid>
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Default capture mode" Style="{StaticResource SettingLabel}" />
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SegmentedContainer}"
                        Margin="0,8" HorizontalAlignment="Right">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="SnapModeDisplay" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapMode" Content="Display" MinWidth="84" />
                        <RadioButton x:Name="SnapModeWindow" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapMode" Content="Window" MinWidth="84" />
                        <RadioButton x:Name="SnapModeCustom" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="SnapMode" Content="Custom" MinWidth="84" />
                    </UniformGrid>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Capture mouse cursor" Style="{StaticResource SettingLabel}" />
                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="SnapCursorSwitch"
                          Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" Margin="0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Library folder" VerticalAlignment="Top" Margin="0,12" />
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,8" HorizontalAlignment="Right">
                    <TextBlock x:Name="SnapLibraryPathText" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" TextAlignment="Right" MaxWidth="320" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button x:Name="SnapOpenLibrary" Content="Open" />
                        <Button x:Name="SnapChangeLibrary" Content="Change…" Margin="8,0,0,0" />
                        <Button x:Name="SnapResetLibrary" Content="Use default" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ===== Video (Snapture) settings ===== -->
            <Grid x:Name="VideoPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Output format" Style="{StaticResource SettingLabel}" />
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SegmentedContainer}"
                        Margin="0,8" HorizontalAlignment="Right">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="VidFormatMp4" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidFormat" Content="MP4" MinWidth="76" />
                        <RadioButton x:Name="VidFormatWebp" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidFormat" Content="WebP" MinWidth="76" />
                        <RadioButton x:Name="VidFormatGif" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidFormat" Content="GIF" MinWidth="76" />
                    </UniformGrid>
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Default capture mode" Style="{StaticResource SettingLabel}" />
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SegmentedContainer}"
                        Margin="0,8" HorizontalAlignment="Right">
                    <UniformGrid Rows="1" Columns="3">
                        <RadioButton x:Name="VidModeDisplay" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidMode" Content="Display" MinWidth="84" />
                        <RadioButton x:Name="VidModeWindow" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidMode" Content="Window" MinWidth="84" />
                        <RadioButton x:Name="VidModeCustom" Style="{StaticResource SegmentRadioButton}"
                                     GroupName="VidMode" Content="Custom" MinWidth="84" />
                    </UniformGrid>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Frame rate" Style="{StaticResource SettingLabel}" />
                <Grid Grid.Row="2" Grid.Column="1" Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="FpsSlider" Grid.Column="0" Minimum="5" Maximum="60"
                            TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                    <TextBlock x:Name="FpsValue" Grid.Column="1" MinWidth="56" TextAlignment="Right"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Quality" Style="{StaticResource SettingLabel}" />
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="QualitySlider" Grid.Column="0" Minimum="0" Maximum="100"
                            TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                    <TextBlock x:Name="QualityValue" Grid.Column="1" MinWidth="56" TextAlignment="Right"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Capture mouse cursor" Style="{StaticResource SettingLabel}" />
                <CheckBox Grid.Row="4" Grid.Column="1" x:Name="VidCursorSwitch"
                          Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" Margin="0,8" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Library folder" VerticalAlignment="Top" Margin="0,12" />
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,8" HorizontalAlignment="Right">
                    <TextBlock x:Name="VidLibraryPathText" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" TextAlignment="Right" MaxWidth="320" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button x:Name="VidOpenLibrary" Content="Open" />
                        <Button x:Name="VidChangeLibrary" Content="Change…" Margin="8,0,0,0" />
                        <Button x:Name="VidResetLibrary" Content="Use default" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Shared settings -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Stream Deck server" VerticalAlignment="Center" Margin="0,12" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8" HorizontalAlignment="Right">
                <CheckBox x:Name="ServerCheck" Content="Enable on port" VerticalAlignment="Center" />
                <TextBox x:Name="PortBox" Width="80" Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="FfmpegStatus"
                       Margin="0,12,0,0" FontSize="12" TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" Cursor="Hand" ToolTipService.InitialShowDelay="200"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="StartButton" Style="{StaticResource RecordButton}" Content="● Start capture" Padding="18,8" />
            <Button x:Name="CloseButton" Content="Close" Margin="10,0,0,0" Padding="18,8" />
        </StackPanel>
    </Grid>
</Window>
